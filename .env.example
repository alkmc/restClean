# HTTP
HTTP_HOST=
HTTP_PORT=8080
HTTP_INTERNAL_PORT=8081
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=120s
HTTP_SHUTDOWN_TIMEOUT=10s
HTTP_REQUEST_TIMEOUT=2s
HTTP_MAX_BODY_BYTES=1048576
HTTP_COMPRESS_MIN_BYTES=1024

CORS_ALLOWED_ORIGINS=
CORS_MAX_AGE=600
HSTS_ENABLED=false
HSTS_MAX_AGE=31536000

# Postgres
PG_HOST=postgres
PG_PORT=5432
PG_USER=pguser
PG_PASSWORD=changeit
PG_DB=restapdb
PG_SSLMODE=disable
PG_MAX_OPEN_CONNS=25
PG_MAX_IDLE_CONNS=5
PG_CONN_MAX_LIFETIME=30m

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeit
REDIS_DB=0
REDIS_CACHE_TTL=60s

# Service
SERVICE_LOAD_TIMEOUT=1s

# Logging
LOG_LEVEL=info
