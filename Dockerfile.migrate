FROM golang:1.26 AS builder

LABEL maintainer="Alex <github.com/alkmc>"

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-w -s" -o migrate ./cmd/migrate

FROM gcr.io/distroless/static-debian13:nonroot

COPY --from=builder --chown=nonroot:nonroot /app/migrate /migrate

USER nonroot:nonroot

ENTRYPOINT ["/migrate"]
